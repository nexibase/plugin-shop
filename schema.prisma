model ProductCategory {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(50)
  slug        String    @unique @db.VarChar(50)
  description String?   @db.Text
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  products    Product[]

  @@index([isActive])
  @@map("product_categories")
}

model Product {
  id          Int              @id @default(autoincrement())
  categoryId  Int?
  name        String           @db.VarChar(200)
  slug        String           @unique @db.VarChar(200)
  description String?          @db.Text
  content     String?          @db.LongText
  price       Int
  originPrice Int?
  images      String?          @db.Text
  optionName1 String?          @db.VarChar(20)
  optionName2 String?          @db.VarChar(20)
  optionName3 String?          @db.VarChar(20)
  isActive    Boolean          @default(true)
  isSoldOut   Boolean          @default(false)
  sortOrder   Int              @default(0)
  viewCount   Int              @default(0)
  soldCount   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  stock       Int              @default(0)
  orderItems  OrderItem[]
  options     ProductOption[]
  qnas        ProductQna[]
  reviews     ProductReview[]
  category    ProductCategory? @relation(fields: [categoryId], references: [id])
  wishlists   Wishlist[]

  @@index([categoryId])
  @@index([isActive])
  @@index([isSoldOut])
  @@map("products")
}

model ProductOption {
  id        Int     @id @default(autoincrement())
  productId Int
  option1   String? @db.VarChar(50)
  option2   String? @db.VarChar(50)
  option3   String? @db.VarChar(50)
  price     Int
  stock     Int     @default(0)
  sku       String? @db.VarChar(50)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, option1, option2, option3])
  @@index([productId])
  @@map("product_options")
}

model DeliveryFee {
  id         Int     @id @default(autoincrement())
  name       String  @db.VarChar(50)
  regions    String  @db.Text
  fee        Int
  freeAmount Int?
  isDefault  Boolean @default(false)
  isActive   Boolean @default(true)
  sortOrder  Int     @default(0)

  @@map("delivery_fees")
}

model Order {
  id              Int             @id @default(autoincrement())
  orderNo         String          @unique @db.VarChar(20)
  userId          Int
  ordererName     String          @db.VarChar(50)
  ordererPhone    String          @db.VarChar(20)
  ordererEmail    String?         @db.VarChar(100)
  recipientName   String          @db.VarChar(50)
  recipientPhone  String          @db.VarChar(20)
  zipCode         String          @db.VarChar(10)
  address         String          @db.VarChar(200)
  addressDetail   String?         @db.VarChar(100)
  deliveryMemo    String?         @db.VarChar(200)
  totalPrice      Int
  deliveryFee     Int             @default(0)
  finalPrice      Int
  status          String          @default("pending") @db.VarChar(20)
  paymentMethod   String?         @db.VarChar(20)
  paymentInfo     String?         @db.Text
  paidAt          DateTime?
  trackingCompany String?         @db.VarChar(50)
  trackingNumber  String?         @db.VarChar(50)
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelReason    String?         @db.Text
  cancelledAt     DateTime?
  refundAmount    Int?
  refundedAt      DateTime?
  adminMemo       String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  items           OrderItem[]
  user            User            @relation(fields: [userId], references: [id])
  reviews         ProductReview[]
  auction         Auction?

  @@index([userId])
  @@index([status])
  @@index([orderNo])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("orders")
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int
  productId   Int?
  optionId    Int?
  productName String  @db.VarChar(200)
  optionText  String? @db.VarChar(200)
  price       Int
  quantity    Int
  subtotal    Int
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model ShopSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("shop_settings")
}

model PendingOrder {
  id        Int      @id @default(autoincrement())
  orderNo   String   @unique @db.VarChar(20)
  userId    Int
  orderData String   @db.LongText
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("pending_orders")
}

model ProductReview {
  id          Int       @id @default(autoincrement())
  productId   Int
  userId      Int
  orderId     Int
  orderItemId Int       @unique
  rating      Int
  content     String    @db.Text
  images      String?   @db.Text
  reply       String?   @db.Text
  repliedAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  order       Order     @relation(fields: [orderId], references: [id])
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([orderId])
  @@index([createdAt])
  @@map("product_reviews")
}

model ProductQna {
  id         Int       @id @default(autoincrement())
  productId  Int
  userId     Int
  question   String    @db.Text
  isSecret   Boolean   @default(false)
  answer     String?   @db.Text
  answeredAt DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
  @@map("product_qnas")
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("wishlists")
}
